{
  "name": "iteco-product-configurator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:prod": "next dev --turbopack --env-file .env.prod.local",
    "build": "next build",
    "start": "next start",
    "format": "biome check --write --formatter-enabled=true --linter-enabled=false .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "lint": "biome lint .",
    "test": "vitest",
    "test:run": "vitest run",
    "zod": "npx tsx ./validation/zod-test-file.ts",
    "type-check": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "type-check:incremental": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit --incremental",
    "erp:sync": "npx tsx ./lib/db-sync/erp-sync.ts",
    "erp:sync:prod": "npx tsx ./lib/db-sync/erp-sync-prod.ts",
    "seed": "npx tsx ./db/seed.ts",
    "seed:reset": "npx tsx ./db/seed.ts --reset",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "drizzle:push": "npx drizzle-kit push",
    "drizzle:push:prod": "npx drizzle-kit push --config=drizzle-prod.config.ts",
    "review": "codex review --base origin/main - < .codex/prompts/review.md",
    "review:uncommitted": "codex review --uncommitted - < .codex/prompts/review.md"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@testing-library/dom": "^10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-themes": "1.0.0-beta.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@hookform/devtools": "^4.4.0",
    "@next/env": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/mssql": "^9.1.11",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "mssql": "^12.2.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom"
  },
  "type": "module"
}
